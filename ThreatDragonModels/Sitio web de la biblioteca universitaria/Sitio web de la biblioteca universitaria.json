              "handlesCardPayment": false,
              "handlesGoodsOrServices": false,
              "isWebApplication": false,
              "privilegeLevel": "",
              "threats": [
                {
                  "id": "645568eb-b19a-4606-a6bd-3c205e8a7c77",
                  "title": "Negación de  servicio ",
                  "status": "Open",
                  "severity": "Medium",
                  "type": "Denial of service / Denegación de servicio",
                  "description": "Un atacante podría denegar el \nacceso a usuarios válidos, \nhaciendo que el servidor web \nno esté disponible o sea \ninutilizable temporalmente \npor medio del envío de \nmúltiples peticiones \nsimultaneas.",
                  "mitigation": "Se utiliza un balanceo de \ncargas en el servidor web. \nSe monitorean las \ndirecciones IP de los \nclientes y al encontrar un \nposible ataque, se bloquea \nel acceso. \nSe considera contratar un \nservicio de VPN para \nocultar la dirección IP \npública a los clientes. \n \nEsta en desarrollo el \nbalanceo de cargas. \nParcialmente mitigada. ",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 3,
                  "score": "2"
                }
              ],
